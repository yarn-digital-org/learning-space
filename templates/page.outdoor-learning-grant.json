 give you the best value for money alongside the highest-quality resources. Learning SPACE are also on the EDR 24-001 Classroom resources tender, Lot 6 – Educational Play Equipment. <\/p><p>Call the Learning SPACE Education Advisors on <a href=\"tel:+442890319360\">02890 319360<\/a> fill in the form and someone will call you back to discuss your needs. <\/p>","link":"","link_label":"","padding_top_desktop":30,"padding_bottom_desktop":30,"padding_top_mobile":20,"padding_bottom_mobile":20}},"ss_circle_menu_baNKEB":{"type":"ss-circle-menu","blocks":{"image_meqNCD":{"type":"Image","settings":{"bubble_img":"shopify:\/\/shop_images\/Screenshot_2025-02-27_131944.png","bubble_text":"Outdoor Classroom","bubble_link":"https:\/\/learningspaceuk.co.uk\/collections\/cosy?sort_by=relevance&q=outdoor+classroom"}},"image_KKMjJF":{"type":"Image","settings":{"bubble_img":"shopify:\/\/shop_images\/Screenshot_2025-02-27_132016.png","bubble_text":"Playground Equipment","bubble_link":"https:\/\/learningspaceuk.co.uk\/collections\/cosy?sort_by=relevance&q=playground"}},"image_HnJNne":{"type":"Image","settings":{"bubble_img":"shopify:\/\/shop_images\/Screenshot_2025-02-27_132037.png","bubble_text":"Outdoor Climbing Frames","bubble_link":"https:\/\/learningspaceuk.co.uk\/collections\/cosy?sort_by=relevance&q=climbing"}},"image_BnkDMP":{"type":"Image","settings":{"bubble_img":"shopify:\/\/shop_images\/Screenshot_2025-02-27_132052.png","bubble_text":"Mud Kitchens","bubble_link":"https:\/\/learningspaceuk.co.uk\/collections\/cosy?sort_by=relevance&q=mud+kitchen"}},"image_MT3LzW":{"type":"Image","settings":{"bubble_img":"shopify:\/\/shop_images\/Screenshot_2025-02-27_132106.png","bubble_text":"Greenhouses & Planters","bubble_link":"https:\/\/learningspaceuk.co.uk\/collections\/cosy?sort_by=relevance&q=plant&page=2"}},"image_dJLyJi":{"type":"Image","settings":{"bubble_img":"shopify:\/\/shop_images\/Outdoor-Garden-Joined-Unit-3-5Yrs-Small-70m2-4.webp","bubble_text":"Pre Made Sets","bubble_link":"