<script>
document.addEventListener("DOMContentLoaded", function () {

    
    const container = document.getElementById("tabContentSource");
    const headings = container.querySelectorAll("h2");

    if (!headings.length) return;

    // Create tabs nav
    const nav = document.createElement("ul");
    nav.className = "nav nav-pills";
    nav.role = "tablist";

    // Create tab content wrapper
    const tabContent = document.createElement("div");
    tabContent.className = "tab-content";

    headings.forEach((heading, index) => {
        const tabId = `tab-${index}`;

        // Create nav item
        const li = document.createElement("li");
        li.className = "nav-item";

        const button = document.createElement("button");
        button.className = `nav-link ${index === 0 ? "active" : ""}`;
        button.setAttribute("data-bs-toggle", "tab");
        button.setAttribute("data-bs-target", `#${tabId}`);
        button.type = "button";
        button.innerText = heading.innerText;

        li.appendChild(button);
        nav.appendChild(li);

        // Create tab pane
        const pane = document.createElement("div");
        pane.className = `tab-pane fade ${index === 0 ? "show active" : ""}`;
        pane.id = tabId;

        // Move content until next heading
        let next = heading.nextElementSibling;
        while (next && next.tagName !== "H2") {
            const temp = next.nextElementSibling;
            pane.appendChild(next);
            next = temp;
        }

        tabContent.appendChild(pane);
        heading.remove();
    });

    container.prepend(nav);
    container.appendChild(tabContent);
});

document.addEventListener("DOMContentLoaded", function () {
    const container = document.getElementById("tabContentMobile");
    if (!container) return;

    const headings = container.querySelectorAll("h2");
    if (!headings.length) return;

    const accordion = document.createElement("div");
    accordion.className = "accordion";
    accordion.id = "productAccordion";

    headings.forEach((heading, index) => {
        const collapseId = `collapse-${index}`;

        const item = document.createElement("div");
        item.className = "accordion-item";

        item.innerHTML = `
            <h2 class="accordion-header">
                <button 
                    class="accordion-button ${index === 0 ? "" : "collapsed"}"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#${collapseId}"
                    aria-expanded="${index === 0}">
                    ${heading.innerText}
                </button>
            </h2>
            <div 
                id="${collapseId}" 
                class="accordion-collapse collapse ${index === 0 ? "show" : ""}">
                <div class="accordion-body"></div>
            </div>
        `;

        let next = heading.nextElementSibling;
        while (next && next.tagName !== "H2") {
            const temp = next.nextElementSibling;
            item.querySelector(".accordion-body").appendChild(next);
            next = temp;
        }

        accordion.appendChild(item);
        heading.remove();
    });

    container.appendChild(accordion);

    /* 🔥 Allow only one open at a time */
    accordion.addEventListener("show.bs.collapse", function (e) {
        accordion.querySelectorAll(".accordion-collapse.show").forEach((openItem) => {
            if (openItem !== e.target) {
                bootstrap.Collapse.getOrCreateInstance(openItem).hide();
            }
        });
    });
});



document.addEventListener("DOMContentLoaded", function () {

    const desktop = document.getElementById("tabContentSource");
    const mobile = document.getElementById("tabContentMobile");

    if (!desktop || !mobile) return;

    function toggleView() {
        if (window.innerWidth < 768) {
            desktop.classList.add("d-none");
            mobile.classList.remove("d-none");
        } else {
            mobile.classList.add("d-none");
            desktop.classList.remove("d-none");
        }
    }

    toggleView();
    window.addEventListener("resize", toggleView);
});

</script>



