<style>
    .st-wishlist-button .st-label {
      display:none;
    }
    .st-wishlist-button{
        border-radius: 7px !important;
    }
   .product-detail .preview-thumbnail.nav-tabs li {
    width: 90%;
    margin-right: 0.5%; }
    .product-detail .preview-thumbnail.nav-tabs li img {
      max-width: 100%;
      display: block; }
    .product-detail .preview-thumbnail.nav-tabs li a {
      padding: 0;
      margin: 0; }
    .product-detail .preview-thumbnail.nav-tabs li:last-of-type {
      margin-right: 0; }

.product-detail .tab-content {
  overflow: hidden; }
  .product-detail .tab-content img {
    width: 100%;
    -webkit-animation-name: opacity;
            animation-name: opacity;
    -webkit-animation-duration: .3s;
            animation-duration: .3s; 
        }
        .product-form__input.product-form__quantity{
        width:inherit !important;
    }
    .qty-col .input-group-text{
        background: #002132;
  border-color: #002132;
    }
    .product-form__quantity input, .product-form__quantity .form-control:focus {
	background: #fff;
	text-align: center;
	border: 0;
	color: #000;
}
.project-detail-column .preview {
background-color: #f4f4f4;
border: 1px #e8e8e8 solid;
border-radius: 8px;
padding: 15px;
display:flex;
align-items: center;
}
#tabContentSource ul li{
text-align:left;
}
.product-detail .nav-pills .nav-link{

  font-weight: bold;
}
.product-detail .nav-pills .nav-link.active{
color: #0173ae;
  box-shadow: 0px 3px 0px #0173ae !important;
  border-radius: 0;
  font-weight: bold;
}

#tabContentSource .tab-content{
background: #f5f5f5;
  border: 1px #e8e8e8 solid;
  padding: 15px;
}
.product-detail .product-title {
	font-size: 30px;
	font-weight: 700;
	color: #2a6099;
    display: flex;
  justify-content: space-between;
  margin-bottom: 25px;
}
.add-cart-center .add-to-cart{
    margin:0 10px
}
.add-cart-center .add-to-cart {
	background: #e00e5d;
	border-color: #e00e5d;
	opacity: 1;
	border: 0;
	/* width: 50% !important; */
	background-size: unset;
	padding-right: 30px;
	padding-left: 30px;
}
.price-incl small{
font-size: .45em;
}
.price-excl strong{
font-size:17px;
}
.add-to-cart{
width: auto;
}
.product-detail .product-title button{
border-radius: 5px;
  box-shadow: 0px 0px 3px #9C9C9C;
}
.product-code-box {
    text-align: center;
}
.product-code-box .product-code-label{
    background: #d7d7d7;
  padding: 6px 15px;
  border-radius: 8px;
}
.product-code-box .product-code-label strong{
    color: #2a6099;
}
.vat-relief-box,.wheels-vat{
    background:#f5f5f5;
    border: 1px #e8e8e8 solid;
    padding:15px
}
.vat-relief-box button {
    background-color: #0173ae;
        border: 1px #0173ae solid;
}
.wheels-vat .form-check {
	display: inline-block;
	margin-right: 20px;
	/* padding-left: 14px; */
}
.wheels-vat .form-check p{
margin-bottom:0;}
.wheels-section {
	border-bottom: 1px #e8e8e8 solid;
	margin-bottom: 10px;
	padding-bottom: 10px;
}
.wheels-section:last-child{
border-bottom:0;
	margin-bottom: 0;
	padding-bottom: 0;
}
.wheels-section:nth-child(2){
border-bottom:0;
	margin-bottom: 0;
	padding-bottom: 0;
}

.stocks-item-cart {
	background: #024366;
	margin-top: 15px;
	border-radius: 8px;
	color: #fff;
}
.stocks-item-cart .progress{
    height: 5px;
}
.stocks-item-cart .price-box {
	background-color: #002132;
	margin-left: 15px;
	border-radius: 5px;
	padding: 6px;
}
.project-detail-column .quantity-section {
	display: flex;
	align-items: center;
    font-size: 18px;
  font-weight: 300;
}
.project-detail-column .quantity-section label{
    margin-bottom: 0;
    margin-right: 10px;
}
.add-cart-center{
 text-align: center;
  margin-bottom: -20px;
}
.product-title-wishlist{
  display: flex;
  align-items: self-start;
}
.MagicToolboxContainer.layout-left .MagicToolboxSelectorsContainer{
margin-right:0;
}
.preview .row{
width:100%;
}
.peppy-notify-me-button-container:hover, .peppy-notify-me-button:hover, .peppy-popup-form-close-button:hover, .peppy-popup-form-notifyme-button:hover {
	opacity: 1 !important;
}
.peppy-notify-me-button-container{
width:auto;
padding-left:30px;
padding-right:30px;
}
.peppy-notify-me-button-container button{
padding-left:30px !important;
padding-right:30px !important;}
.sd_my_tab_description{
    display: none !important;
}
@media only screen and (min-width: 320px) and (max-width: 768px) {
    .project-detail-column .quantity-section {
	display: flex;
	align-items: center;
	align-content: center;
	justify-content: center;
}


.stocks-item-cart .price-box {
	margin-left: 15px;
	margin-right: 15px;
}
.product-form__input.product-form__quantity input {
	width: 50px !important;
}
.preview .row{
width:100%;
margin:0 auto;
}
.price-quantity-section button{
font-size:10px !important}
}
#productAccordion .accordion-item{
margin-bottom:10px;
background:#f5f5f5;

}
#productAccordion .accordion-item .accordion-button {
	color: #000;
	background: none;
	border-top: 1px #dee2e6 solid;
	padding: 7px;
	font-size: 14px;
	font-weight: 500;
}
#productAccordion .accordion-item ul{
padding-left:0
}
#productAccordion .accordion-item .accordion-body{
text-align: left;
  max-height: 250px;
  overflow-y: scroll;
  color:#2c2c2c;
  color: #2c2c2c;
  font-size: 13px;
}
}
@media only screen and (min-width: 769px) and (max-width: 1300px) {
    .project-detail-column .quantity-section {
display: inline !important;
}
}
.visibility-hidden{
 visibility: hidden;
}

</style>
<div class="container product-detail project-detail-column mt-5">
    <div class="row mb-5">
        <div class="preview col-md-6">
            <div class="row">
            {% comment %}magictoolbox code begins{% endcomment %}
            {% capture mzp %}{% render 'magiczoomplus', product:product %}{% endcapture %}
            {% if mzp contains 'Liquid error' %}
            {% comment %}magictoolbox replace code begins{% endcomment %}
            {%- if product.media.size > 0 -%}
            <div class="productflexslider">
                <ul class="slides">
                    {% for media in product.media %}
                    {% assign dataThumb = media.preview_image.src | img_url: 'large' %}
                    {% comment %}
                    {% if media.media_type == 'external_video' %}
                    {% assign dataThumb = 'https://cdn.shopify.com/s/files/1/0649/0688/7411/files/video-play-img.png?v=1697173669' %}
                    {%- endif -%}
                    {% endcomment %}
                    {%- assign overimage = '' -%}
                    {%- if media.media_type == 'external_video' -%}
                    {%- assign overimage = 'https://cdn.shopify.com/s/files/1/0649/0688/7411/files/play-button.png?v=1701158134' -%}
                    {%- endif -%}
                    <li data-thumb="{{ dataThumb }}" data-overimage="{{ overimage }}" class="{% if media.media_type == 'external_video' %}special-thumbnail{% endif %}">
                        {% case media.media_type %}
                        {% when 'external_video' %}
                        <div class="product-single__video">
                            {{ media | external_video_tag }}
                        </div>
                        {% when 'video' %}
                        <div class="product-single__video">
                            {{ media | video_tag: controls: true }}
                        </div>
                        {% when 'image' %}
                        <div class="thumb-image product_grpup_sticker">
                            {% if product.metafields.custom.markers %}
                            <img src="{{ product.metafields.custom.markers | img_url: 'large' }}" alt="markers" class="product_sticker" id="variant_image_sticker" height="auto" width="auto" />
                            {% endif %}
                            <img src="{{ media.src | img_url: 'large' }}" class="zoom-images" alt="{{ media.alt | escape }}" id="variant_image_{{ media.id }}" height="auto" width="auto"/>
                        </div>
                        {% endcase %}
                    </li>
                    {% endfor %}
                </ul>
                <div class="clearfix"></div>
            </div>
            {%- else %}
            <div class="col-3">
                <img src="{{ 'img.jpg' | asset_url }}" class="img-responsive" alt="{{ 'img.jpg' | asset_url }}" height="auto" width="auto">
            </div>
            {%- endif -%}
            {% comment %}magictoolbox replace code ends{% endcomment %}
            {% else %}
            <div style="display:none">
                {%- if product.media.size > 0 -%}
                <div class="productflexslider">
                    <ul class="slides">
                        {% for media in product.media %}
                        {% assign dataThumb = media.preview_image.src | img_url: 'large' %}
                        {% comment %}
                        {% if media.media_type == 'external_video' %}
                        {% assign dataThumb = 'https://cdn.shopify.com/s/files/1/0649/0688/7411/files/video-play-img.png?v=1697173669' %}
                        {%- endif -%}
                        {% endcomment %}
                        {%- assign overimage = '' -%}
                        {%- if media.media_type == 'external_video' -%}
                        {%- assign overimage = 'https://cdn.shopify.com/s/files/1/0649/0688/7411/files/play-button.png?v=1701158134' -%}
                        {%- endif -%}
                        <li data-thumb="{{ dataThumb }}" data-overimage="{{ overimage }}" class="{% if media.media_type == 'external_video' %}special-thumbnail{% endif %}">
                            {% case media.media_type %}
                            {% when 'external_video' %}
                            <div class="product-single__video">
                                {{ media | external_video_tag }}
                            </div>
                            {% when 'video' %}
                            <div class="product-single__video">
                                {{ media | video_tag: controls: true }}
                            </div>
                            {% when 'image' %}
                            <div class="thumb-image product_grpup_sticker">
                                {% if product.metafields.custom.markers %}
                                <img src="{{ product.metafields.custom.markers | img_url: 'large' }}" alt="markers" class="product_sticker" id="variant_image_sticker" height="auto" width="auto" />
                                {% endif %}
                                <img src="{{ media.src | img_url: 'large' }}" class="zoom-images" alt="{{ media.alt | escape }}" id="variant_image_{{ media.id }}" height="auto" width="auto"/>
                            </div>
                            {% endcase %}
                        </li>
                        {% endfor %}
                    </ul>
                    <div class="clearfix"></div>
                </div>
                {%- else %}
                <img src="{{ 'img.jpg' | asset_url }}" class="img-responsive" alt="{{ 'img.jpg' | asset_url }}" height="auto" width="auto">
                {%- endif -%}</div>
             {{ mzp }}
            {% endif %}
            {% comment %}magictoolbox code ends{% endcomment %}
        </div>
        </div>
        <div class="details col-md-6">
            {% assign bespokeCollection = false %}
            {% for tag in product.tags %}
            {% if tag == 'bespoke' %}
            {% assign bespokeCollection = true %}
            {% endif %}
            {% endfor %}
            {% if current_variant.compare_at_price > current_variant.price %}
            <span class="spf-product__label spf-product__label-sale sale-text" id="sale-label-{{ section.id }}">
                {{translation.product.sale | default: "Sale"}}
            </span>
            {% else %}
            <span id="sale-label-{{ section.id }}"></span>
            {% endif %}
            <div class="product-title-wishlist">
                <h3 class="product-title">
                    {{ product.title }}
                
                </h3>
                <button class='st-wishlist-button' data-type='details' data-handle='{{ product.handle }}'></button> 
            </div>
            {% if bespokeCollection == true %}
            <p>This is a bespoke item so please contact us for a quote.</p>
            {% endif %}

            
            <div class="product-code-box mb-3">
                <div class="hideAll">
                   <span class="product-code-label">
                        Product Code:
                        <strong class="sku fs-14" ></strong>
                    </span>
                </div>
            </div>
             <div class="vat-relief-box {% if current_variant.metafields.global.vat_relief_variant %} available mb-2 {% else %} hide {% endif %}" style="" id="vat_relief_variant_note-{{ section.id }}">
                You have selected a VAT exempt option. Note that you will need to complete a VAT Relief Declaration form prior to checking out.
            </div>
            {%- assign product_form_id = 'product-form-' | append: section.id -%}
            {%- form 'product', product, id: product_form_id, class: 'form product-form', novalidate: 'novalidate', data-type:'add-to-cart-form' -%}
            <input type="hidden" name="id" id="variant_id" value="{{ product.selected_or_first_available_variant.id }}">
            <input type="hidden" name="properties[tax_free]" id="is_prod_tax_free" value="{{ product.metafields.global.is_tax_free }}">
            <input type="hidden" name="properties[ex_price]" id="ex_price" value="{{ priceEx | replace: ",", "."  }}">
            <input type="hidden" name="properties[is_vat_relief]" id="is_vat_relief" value="{{ isVatReilefProduct  }}">
            {% if product.variants.size > 1 %}
            {% if isVatReilefProduct %}
            <div class="vat-relief-box mb-4 p-3">
                <p class="mb-0"><strong>This product eligible for VAT relief</strong> Please choose the relevant option. 
                <button class="btn btn-primary btn-sm ms-2"  data-bs-toggle="modal" data-bs-target="#vatReliefModal">Do I Qualify?</button></p>
            </div>
            {% endif %}
            <div class="wheels-vat">
            <variant-selects class="no-js-hidden single-option-selector" data-section="{{ section.id }}" data-url="{{ product.url }}" {{ block.shopify_attributes }}>
                {%- for option in product.options_with_values -%}
                <div class="wheels-section">
                    <h5>{{ option.name }}</h5>
                        <div id="Option-{{ section.id }}-{{ forloop.index0 }}">
                            {%- for value in option.values -%}
                                <div class="form-check">
                                    <label class="form-check-label" for="flexRadioDefault-{{ forloop.index0 }}">
                                        <p>{{ value | escape }}</p>
                                    </label>
                                    <input {% if option.selected_value==value%} checked="checked" {% endif %} class="form-check-input" type="radio" name="options-{{ option.name | escape }}" id="flexRadioDefault-{{ forloop.index0 }}" form="{{ product_form_id }}" value="{{ value | escape }}">
                                </div>
                       
                            {%- endfor -%}
                        </div>
                    
                </div>
                {%- endfor -%}
                <script type="application/json">
                {{ product.variants | json }}
                </script>
            </variant-selects>
        </div>
            <div class="modal fade" id="vatReliefModal" tabindex="-1" aria-labelledby="vatReliefModalArea" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h1 class="modal-title fs-5" id="vatReliefModalArea">Do I qualify for VAT Exemption?</h1>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            If you are disabled or have a long-term illness, you won’t be charged VAT on products designed or adapted for your own personal or domestic use.
                            If you are not entitled to VAT Exemption please close this box and select the price that includes VAT. If you are unsure whether you are entitled or not please read our VAT Exemption Terms & Conditions.
                        </div>
                        <div class="modal-footer">
                            <a href="/pages/vat-relief" class="btn btn-secondary">VAT Exemption Terms & Conditions</a>
                        </div>
                    </div>
                </div>
            </div>
           
            {% endif %}
            <div class="stocks-item-cart">
            <div class="stock-alert-box p-3">

                {% if current_variant.inventory_management == "shopify" and current_variant.inventory_policy != "continue"%}
                <p class="mb-2">Only <strong id="quantity-{{ section.id }}">{{ current_variant.inventory_quantity
                        }} item(s) left in stock!</strong></p>
                <div class="progress">
                    <div class="progress-bar bg-danger" role="progressbar" aria-valuenow="30" aria-valuemin="0" aria-valuemax="100" style="width:30%"> </div>
                </div>
                {% endif %}

            </div>

        



            <div class="price-quantity-section">
              <div class="row d-flex justify-content-center align-items-center">
                <div class=" mb-3 col-md-6" id="priceview--{{ section.id }}">
                  <div class="price-box text-center">

                    {% comment %} Vat and price {% endcomment %}
            {% assign isVatReilefProduct = current_variant.metafields.global.vat_relief_variant %}
            <span class="badge rounded-pill text-bg-primary {% if isVatReilefProduct %} available mb-2 {% else %} hide {% endif %}" id="vat_relief_variant-{{ section.id }}">Vat Relief</span>
            {% comment %}
            <div class="rating mb-4 mt-4">
                <div class="stars">
                    <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
                </div>
            </div>
            {% endcomment %}
            {% assign priceEx = current_variant.price | divided_by:1.20 %}
            {% assign priceExClass = 'style=""' %}
            {% assign priceLabel = 'incl. VAT' %}
            {% if product.metafields.global.is_tax_free == true %}
            {% assign priceEx = 0 %}
            {% assign priceExClass = 'style="visibility:hidden;' %}
            {% assign priceLabel = 'No. VAT' %}
            {% endif %}
            {% assign productID = product.id %}
            {% if bespokeCollection == false %}
            {% if isVatReilefProduct %}
            {% assign priceEx = current_variant.price %}

                <span class="item_price" id="price-{{ section.id }}">
                  {% if current_variant.compare_at_price > current_variant.price %}
                     <h3 class="price-incl mb-1">
                        {{ current_variant.compare_at_price | money | replace: ",", "." }}
                        <span> Old Price</span>
                    </h3>
                     <p class="price-excl mb-0">
                        <strong {{ priceExClass }}>
                            {{ current_variant.price | money | replace: ",", "." }}
                        </strong>
                          incl. VAT
                    </p>
                  {% else %}
                    <h3 class="price-incl mb-1">
                        {% assign result = current_variant.price | times: 1.20 %}
                       {% assign truncated = result | times: 100 | floor | divided_by: 100 %}
                         {{ truncated | money }}
                        <small> {{ priceLabel }}</small>
                    </h3>
                    <p class="price-excl mb-0">
                        <strong {{ priceExClass }}>
                            {{ current_variant.price | money }}
                        </strong>
                        excl. VAT
                    </p>
                   {% endif %}
                </span>
          
            {% else %}
            <h3 class="price mb-4">
                <span class="item_price" id="price-{{ section.id }}">
                    {% if current_variant.compare_at_price > current_variant.price %}
                        <h4 style="color: #0173ae; text-decoration: line-through;">
                            {{ current_variant.compare_at_price | money | replace: ",", "." }}
                            <span> Old Price</span>
                        </h4>
                    
                        <h3 class="price-incl mb-1">
                            {{ current_variant.price | money | replace: ",", "." }}
                            <small> incl. VAT</small>
                        </h3>
                    
                    
                        <p class="price-excl mb-0" {{ priceExClass }}>
                           <strong> {{ priceEx | money }} </strong>
                           excl. VAT
                        </p>
                    
                    {% else %}
                    <h3 class="price-incl mb-1">
                        {{ current_variant.price | money }}
                        <small> {{ priceLabel }}</small>
                    </h3>
                    <p class="price-excl mb-0">
                        <strong {{ priceExClass }}>
                            {{ priceEx | money }}
                            
                        </strong>
                        excl. VAT
                    </p>
                    {% endif %}
                </span>
            </h3>
            {% endif %}
            {% endif %}

          
                  </div>
                </div>
                 <div class="col-md-6 mb-3 {% unless current_variant.available %} hide {% endunless %}" id="quantitysection--{{ section.id }}">
                  <div class="quantity-section" >
                        <label><b>Quantity:</b></label>
                        <div class=" cart-qty-center d-flex justify-content-center " id="quantity-input">
                            <div class="input-group quantity-input">
                                <div class="product-form__input product-form__quantity{% if settings.inputs_shadow_vertical_offset != 0 and settings.inputs_shadow_vertical_offset < 0 %} product-form__quantity-top{% endif %}" {{ block.shopify_attributes }}>
                                    <quantity-input class="quantity input-group qty-col">
                                        <button class="quantity__button no-js-hidden input-group-text" name="minus" type="button">
                                            -
                                        </button>
                                        <input class="quantity__input form-control" type="number" name="quantity" id="Quantity-{{ section.id }}" min="1" max={{ current_variant.inventory_quantity}} value="1" form="{{ product_form_id }}" />
                                        <button class="quantity__button no-js-hidden input-group-text" name="plus" type="button">
                                            +
                                        </button>
                                    </quantity-input>
                                </div>
                            </div>
                        </div>
                  </div>
                </div>
              </div>

               <div class="row">
                        {% if bespokeCollection == false %}
                        {%- if gift_card_recipient_feature_active -%}
