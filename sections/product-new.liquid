            {% for collection_list in collection_lists %}
            {% for p_collection in product.collections %}
            {% if collection_list.id == p_collection.id %}
            {% assign matchCollection = true %}
            {% break %}
            {% endif %}
            {% endfor %}
            {% endfor %}
            {% else %}
            {% assign matchCollection = true %}
