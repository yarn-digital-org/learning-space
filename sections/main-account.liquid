{% comment %} <div class="heading-bg">
	<div class="container-fluid">
		<h1 class="text-center">{{ 'customer.account.title' | t }}</h1>
       
       <h1 class="text-center">Family Fund</h1>
	</div>
</div>
<div class="container-fluid login-section">
    
	<div class="row">
        <p id="successMessage" style="display: none;"></p>
		{% assign customer_order_count = customer.orders.size %}
		{% assign customer_family_fund = customer.metafields.custom.FFC %}
       
		{% render 'accountsidebar', customer_order_count: customer_order_count,customer_family_fund:customer_family_fund
		%}
      
		<div class="col-12 col-md-9">
			<div class="tab-content" id="v-pills-tabContent">
				<div class="tab-pane fade show active" id="v-pills-ff-grants" role="tabpanel" aria-labelledby="v-pills-ff-grants-tab">
					<div id="family-fund-info">
						<div class="spinner-border text-primary" role="status">
							<span class="visually-hidden">Loading...</span>
						</div>
					</div>
					<div id="family-fund-grants"></div>
				</div>
				<div class="tab-pane fade" id="v-pills-ff-transactions" role="tabpanel" aria-labelledby="v-pills-ff-transactions-tab">
					<div id="family-fund-transactions"></div>
				</div>

			</div>
		</div>
	</div>
</div>
<script type="text/javascript">
  const searchParams = new URLSearchParams(window.location.search);
  if(searchParams.has('redirect_from')) {
    if(searchParams.get('redirect_from') == 'signup') {
        setTimeout(function () {
         window.location.href = "/account"; 
        }, 2000); //will call the function after 2 secs.
    }
  }

</script>
<script>
	window.onload = () => {
		typeof CustomerAddresses !== 'undefined' && new CustomerAddresses();
	}
</script> {% endcomment %}
{% schema %}
  {
    "name": "Family Fund Account",
    "settings": []
  }
{% endschema %}