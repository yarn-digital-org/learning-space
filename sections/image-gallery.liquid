<style>
  #shopify-section-{{ section.id }} {
    margin-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.padding_top_mobile }}px;
  }
  @media only screen and (min-width: 992px) {
  #shopify-section-{{ section.id }} {
      margin-bottom: {{ section.settings.padding_bottom_desktop }}px;
      margin-top: {{ section.settings.padding_top_desktop }}px;
    }
  }
  #shopify-section-{{ section.id }} h2 {
    margin-bottom: 40px;
  }
  #shopify-section-{{ section.id }} .img-container {
    margin-bottom: 10px;
  }  
  #shopify-section-{{ section.id }} .img-container.rounded-image {
    overflow: hidden;
    border-radius: 50%;
  }
  #shopify-section-{{ section.id }} .img-container img {
    object-fit: cover;
    height: 100%;
    width: 100%;
  }  
</style>
<div class="container text-{{ section.settings.align_text }}">
  <div class="row">
    <div class="col">
      <h2>{{ section.settings.title }}</h2>
    </div>
  </div>
  <div class="row">
    
    {% for block in section.blocks %}
    <div class="col-{{ section.settings.column_layout_mobile }} col-sm-{{ section.settings.column_layout_tablet }} col-lg-{{ section.settings.column_layout_desktop }}">
      {% if block.settings.image != blank %}
       <a href="{{ block.settings.link }}"> 
      <div class="img-container{% if block.settings.round_img == true %} rounded-image{% endif %}">
        {%- assign image_alt = block.settings.image.alt -%}
        {{ block.settings.image | img_url: 'master' | img_tag: image_alt }}
      </div>
       </a>
      {% endif %}
      <div class="text-container">
        {% if block.settings.title != blank %}
          <h3>{{ block.settings.title | escape }}</h3>
        {% endif %}        
          <div class="rte">
            {% if block.settings.text != blank %}
              {{ block.settings.text }}
            {% endif %}
            {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>
            {% endif %}
          </div>
        
      </div>
    </div>
    {% endfor %}
  </div>
</div>

{% schema %}
  {
    "name": "Image gallery",
    "class": "image-gallery-section",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "Text columns with images"
      },
	  {
        "type": "select",
        "id": "column_layout_desktop",
        "label": "Columns in a row for desktop",
        "options": [
          {
            "value": "6",
            "label": "2"
          },
         
          {
            "value": "4",
            "label": "3"
          },
		  {
            "value": "3",
            "label": "4"
          },
           {
            "value": "20",
            "label": "5"
          },
		  {
            "value": "2",
            "label": "6"
          }
        ]
      },
	  {
        "type": "select",
        "id": "column_layout_tablet",
        "label": "Columns in a row for tablet",
        "options": [
          {
            "value": "6",
            "label": "2"
          },
          {
            "value": "4",
            "label": "3"
          },
		  {
            "value": "3",
            "label": "4"
          }
        ]
      },
	  {
        "type": "select",
        "id": "column_layout_mobile",
        "label": "Columns in a row for mobile",
        "options": [
          {
            "value": "",
            "label": "1"
          },
          {
            "value": "6",
            "label": "2"
          }
        ]
      },
      {
        "type": "select",
        "id": "align_text",
        "label": "Text alignment",
        "default": "left",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Centered"
          }
        ]
      },
      {
        "type": "header",
        "content": "Section gaps"
      },
      {
        "type": "range",
        "id": "padding_top_desktop",
        "label": "Section top gap in desktop",
        "step": 1,
        "min": 0,
        "max": 100,
        "default": 30,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "padding_bottom_desktop",
        "label": "Section bottom gap in desktop",
        "step": 1,
        "min": 0,
        "max": 100,
        "default": 30,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "padding_top_mobile",
        "label": "Section top gap in mobile",
        "step": 1,
        "min": 0,
        "max": 100,
        "default": 20,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "padding_bottom_mobile",
        "label": "Section bottom gap in mobile",
        "step": 1,
        "min": 0,
        "max": 100,
        "default": 20,
        "unit": "px"
      }
    ],
    "blocks": [
      {
        "type": "gallery_item",
        "name": "image",
        "settings": [
		  {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "checkbox",
            "id": "round_img",
            "label": "Make image round",
            "default": true
          },
          {
            "type": "text",
            "id": "title",
            "label": "Heading",
            "default": "Text columns with images"
          },
          {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>Share blog posts, products, or promotions with your customers. Use this text to describe products, share details on availability and style, or as a space to display recent reviews or FAQs.</p>"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          },
          {
            "type": "text",
            "id": "link_label",
            "label": "Link label"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Image gallery",
        "category": "Image",
        "blocks": [
          {
            "type": "gallery_item"
          }
        ]
      }
    ]
  }
{% endschema %}