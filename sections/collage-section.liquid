<style>
  #shopify-section-{{ section.id }} {
    margin-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.padding_top_mobile }}px;
  }
  .collage-item {
    margin-bottom: 10px;
    position: relative;
  }
  .collage-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 20px;
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 100%;
  }
  .collage-item img {
    border-radius: 8px;
    height: 100%;
    width: 100%;
    object-fit: cover;
    vertical-align: top;
  }
  @media (min-width: 768px) {
    .collage-item {margin: 0;}
    .parent {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, 1fr);
      grid-column-gap: 10px;
      grid-row-gap: 10px;
    }
    .collage-item-1 { grid-area: 1 / 1 / 3 / 2; }
    .collage-item-2 { grid-area: 1 / 2 / 2 / 3; }
    .collage-item-3 { grid-area: 2 / 2 / 3 / 3; }
  }
  @media only screen and (min-width: 992px) {
    margin-bottom: {{ section.settings.padding_bottom_desktop }}px;
    margin-top: {{ section.settings.padding_top_desktop }}px;
  }
</style>
<div class="container text-{{ section.settings.align_text }}">
  <div class="row">
    <div class="col">
      <h2>{{ section.settings.title }}</h2>
    </div>
  </div>
<div class="parent">
  {% for block in section.blocks %}
    <div class="collage-item collage-item-{{ forloop.index }}">
      {% assign image_alt = block.settings.image.alt %}

{% assign img_width = 1200 %}
{% assign img_height = 600 %} <!-- replace 600 with actual image height maintaining aspect ratio -->

<img 
  src="{{ block.settings.image | image_url: width: img_width }}" 
  srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1200 }} 1200w" 
  sizes="(max-width: 767px) 90vw, (min-width: 768px) 50vw, 1200px" 
  alt="{{ image_alt }}" 
  loading="lazy" 
  width="{{ img_width }}" 
  height="{{ img_height }}" 
  style="width:100%; height:100%; object-fit:cover; border-radius:8px;"
>

      <a href="{{ block.settings.link }}">
        <div class="collage-inner">
          {% if block.settings.title != blank %}
            <h3 style="color: {{ block.settings.title_color }};">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.link_label != blank %}
            <a href="{{ block.settings.link }}" class="btn btn-button">{{ block.settings.link_label }}</a>
          {% endif %}
        </div>
      </a>
    </div>
  {% endfor %}
</div>
</div>
{% schema %}
{
  "name": "Image collage",
  "class": "image-collage-section",
  "max_blocks": 3,
  "settings": [
     {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "header",
      "content": "Section gaps"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Section top gap in desktop",
      "step": 1,
      "min": 0,
      "max": 100,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Section bottom gap in desktop",
      "step": 1,
      "min": 0,
      "max": 100,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Section top gap in mobile",
      "step": 1,
      "min": 0,
      "max": 100,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Section bottom gap in mobile",
      "step": 1,
      "min": 0,
      "max": 100,
      "default": 20,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title color"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image collage",
      "category": "Image"
    }
  ]
}
{% endschema %}