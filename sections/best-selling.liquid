{% if collections['best-saller'].products.size > 0 %}
<section class="feature-pro">
	<div class="container-fluid">
		<h4 class="mb-2 mt-5">{{ section.settings.heading }}</h4>
		<div class="row">
		{% paginate collections['best-saller'].products by 4 %}		
        {% for product in collections['best-saller'].products  %}
	   
          {%- assign price = product.selected_or_first_available_variant.price -%}
    		{% render 'card-product',
    		  card_product: product,
    		  price: price,
    		  handle: product.handle,
    		  variant_size: product.variants.size,
    		  variants: product.variants,
              collections: product.collections
    		%}
		{% endfor %}
		{% endpaginate %}
		</div>
	</div>
</section>
{% endif %}
{% schema %}
{ "name": "Best Saller Products",
  "settings":[{
	"type": "text",
	"id": "heading",
	"label": "Heading Tilte",
	"default":"Best Saller Products"
}] ,
  "presets": 
  [ 
      { 
          "name": "Best Saller Products" 
      }    
  ]
}
{% endschema %}