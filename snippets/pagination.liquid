<div class="col-sm-12">
    {% if paginate.pages > 1 %}
    <nav aria-label="Page navigation example" role="navigation">
      <ul class="pagination pagination-sm justify-content-center">
        {% if paginate.previous %}
          <li class="page-item">
            <a class="page-link" href="{{ paginate.previous.url }}">
              <span aria-hidden="true">&laquo;</span>
              Previous 
            </a>
          </li>
        {% else %}
          <li class="page-item disabled">
            <a href="javascript:void(0)" class="page-link disabled">
                <span aria-hidden="true">&laquo;</span>
                Previous
                </a>
          </li>
        {% endif %}

        {% for part in paginate.parts %}
          {% if part.is_link %}
            <li class="page-item">
              <a class="page-link" href="{{ part.url }}">
                 {{ part.title }}
              </a>
            </li>
          {% else %}
            {% if part.title == paginate.current_page %}
              <li class="page-item active" aria-current="page">
                  <a class="page-link disabled" href="{{ part.url }}">
                 {{ part.title }}
              </a>
              </li>
            {% else %}
            <li class="page-item ">
              <a class="page-link disabled" href="{{ part.url }}">
                 {{ part.title }}
              </a>
              </li>
            {% endif %}
          {% endif %}
        {% endfor %}

        {% if paginate.next %}
        <li class="page-item">
            <a href="{{ paginate.next.url }}" class="page-link">
              Next 
              <span aria-hidden="true">&raquo;</span>
            </a>
          </li>
        {% else %}
          <li class="page-item ">
            <a href="javascript:void(0)" class="page-link disabled">
            Next 
            <span aria-hidden="true">&raquo;</span>
            </a>
          </li>
        {% endif %}
      </ul>
    </nav>
  {% endif %}
  </div>