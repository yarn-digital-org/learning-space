<div class="row  mb-5">
    <div class="col-12 col-md-4 pro-list pro-list-view"> 
      <div class="comparable-product-options" data-product-id="{{product.id}}" data-product-handle="{{product.handle}}"></div> 
        {% if card_product.featured_image != null and card_product.featured_image != "" %}
        <a href="{{ card_product.url | within: collection }}">
            <img
  src="{{ card_product.featured_image | image_url: width: 800, format: 'webp' }}"
  srcset="
    {{ card_product.featured_image | image_url: width: 320, format: 'webp' }} 320w,
    {{ card_product.featured_image | image_url: width: 480, format: 'webp' }} 480w,
    {{ card_product.featured_image | image_url: width: 768, format: 'webp' }} 768w,
    {{ card_product.featured_image | image_url: width: 1024, format: 'webp' }} 1024w,
    {{ card_product.featured_image | image_url: width: 1440, format: 'webp' }} 1440w
  "
  sizes="(max-width: 480px) 320px,
         (max-width: 768px) 480px,
         (max-width: 1024px) 768px,
         800px"
  width="{{ card_product.featured_image.width }}"
  height="{{ card_product.featured_image.height }}"
  alt="{{ card_product.title | escape }}"
  class="img-fluid product-img"
  loading="lazy"
/>
          </a>
        {% else %}
<a href="{{ card_product.url | within: collection }}">
  <img
    src="{{ 'img.jpg' | asset_url | image_url: width: 800, format: 'webp' }}"
    srcset="
      {{ 'img.jpg' | asset_url | image_url: width: 320, format: 'webp' }} 320w,
      {{ 'img.jpg' | asset_url | image_url: width: 480, format: 'webp' }} 480w,
      {{ 'img.jpg' | asset_url | image_url: width: 768, format: 'webp' }} 768w,
      {{ 'img.jpg' | asset_url | image_url: width: 1024, format: 'webp' }} 1024w,
      {{ 'img.jpg' | asset_url | image_url: width: 1440, format: 'webp' }} 1440w
    "
    sizes="(max-width: 480px) 320px,
           (max-width: 768px) 480px,
           (max-width: 1024px) 768px,
           800px"
    width="800"
    height="800"
    alt="Placeholder product image"
    class="img-fluid product-img"
    loading="lazy"
  />
</a>
        {% endif %}
    </div>
    <div class="col-12 col-md-8 pro-list">
      <h6 class=""><a href="{{ card_product.url | within: collection }}">{{ card_product.title | escape }}</a></h6>
      {% if product.metafields.vat.relief and customer %}
            <span class="badge rounded-pill text-bg-primary" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Parents and carers of chronically sick or disabled children are eligible to receive VAT relief, this will be applied at checkout">Vat Relief</span>
            {% endif %}
      {% if settings.show_vendor %}
    <p>{{ card_product.vendor | escape }}</p>
    {% endif %}
    {% if settings.show_ratings %}
    <span class="shopify-product-reviews-badge" data-id="{{ card_product.id }}"></span>
    {% endif %}
         <h6 class="mb-2 mt-1 ex-vat-price">
          <span>excl. VAT : </span>
             {% assign priceEx =  price | divided_by:1.20  %}
             {{ priceEx | money | replace: ",", "." }}
        </h6>
        <h5 class="mb-2 inc-vat-price" >
          <span> incl. VAT : </span>
          {{ price | money | replace: ",", "." }}
          </h5>
      <div class="button-group">
        {% if card_product.variants.size > 1 %}
        <a href="{{ card_product.url | within: collection }}" class="btn btn-primary"> <img src="{{ 'cart-pro.svg' | asset_url }}" alt="cart"> Select Option</a>
        {% else %}
        {% if card_product.variants[0].available %} 
                <button type="button" onclick="addtocart('{{ card_product.variants[0].id }}',1)" class="btn btn-primary"><img src="{{ 'cart-pro.svg' | asset_url }}" alt="buy-now">Buy Now</button>
                  {% else %}
                 <button type="button" class="btn btn-primary" disabled="disabled" ><img src="{{ 'cart-pro.svg' | asset_url }}" alt="sold-out">Sold Out</button>
                {% endif %}
        {% endif %}

        <!-- Swym Wishlist Plus EPI Button-->
        <button data-with-epi="true" class="wishlist_button action--wishlist tile-actions--btn flex btn btn-secondary swym-button swym-add-to-wishlist-view-product product_{{card_product.id}}" data-swaction="addToWishlist" data-product-id="{{card_product.id | json}}" data-variant-id="{{card_product.variants[0].id}}" data-product-url="{{ shop.url }}{{ card_product.url }}">
          <img src="{{ 'heart.svg' | asset_url }}" alt="Wishlist">
          <span class="wishlist_txt">Wishlist</span>
        </button>
        <!-- Swym Wishlist Plus EPI Button-->
        </div>
        
    </div>
</div>
 