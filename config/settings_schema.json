[
  {
    "name": "theme_info",
    "theme_name": "LearningSpace",
    "theme_version": "2.0.0",
    "theme_author": "RKM Software",
    "theme_documentation_url": "https:\/\/github.com\/Shopify\/themekit",
    "theme_support_url": "https:\/\/github.com\/Shopify\/themekit\/issues"
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32 x 32px"
      }
    ]
  },
  {
    "name": "Add to cart notification",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_ajax",
        "label": "Show notification when item is added to cart",
        "default": true
      }
    ]
  },
  {
    "name": "Currency format",
    "settings": [
      {
        "type": "header",
        "content": "Currency codes"
      },
      {
        "type": "paragraph",
        "content": "Cart and checkout prices always show currency codes. Example: $1.00 USD."
      },
      {
        "type": "checkbox",
        "id": "currency_code_enabled",
        "label": "Show currency codes",
        "default": true
      }
    ]
  },
  {
    "name": "Address",
    "settings": [
      {
        "type": "checkbox",
        "id": "address_enabled",
        "label": "Show address",
        "default": true
      },
      {
        "type": "text",
        "id": "address_1",
        "label": "Address 1"
      },
      {
        "type": "text",
        "id": "address_2",
        "label": "Address 2"
      },
      {
        "type": "text",
        "id": "post_code",
        "label": "Postal Code"
      },
      {
        "type": "text",
        "id": "address_phone",
        "label": "Phone No."
      },
      {
        "type": "text",
        "id": "address_email",
        "label": "Email Address"
      }
    ]
  },
  {
    "name": "Family Fund Prompt",
    "settings": [
      {
        "type": "checkbox",
        "id": "familyfundpopup_enable",
        "label": "Show Prompt",
        "default": true
      },
      {
        "type": "image_picker",
        "id": "familyfundpopupimage",
        "label": "Logo image",
        "info": "Will be scaled down to 70 x 70"
      },
      {
        "type": "text",
        "id": "familyfundpopupheading",
        "default": "Family Fund",
        "label": "Heading"
      },
      {
        "type": "text",
        "id": "familyfundpopupdescription",
        "default": "If you are family fund customers. You need to switch currency to GBP.",
        "label": "Description"
      },
      {
        "type": "text",
        "id": "familyfundpopupbuttontext",
        "default": "Switch Currency",
        "label": "Button Label"
      },
      {
        "type": "text",
        "id": "familyfundpopupbutton_link",
        "default": "https:\/\/learningspaceuk.co.uk",
        "label": "Button Link"
      }
    ]
  }
]
